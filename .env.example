# ChamaLeon — Configuracao de Ambiente
# Copie este arquivo para .env e preencha com valores reais

TELEGRAM_BOT_TOKEN=
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/chamaleon

APP_ENV=development
LOG_LEVEL=INFO
AUTO_CREATE_SCHEMA=false
CACHE_TTL_SECONDS=60
REMINDER_CHECK_INTERVAL_MINUTES=15
DAILY_NUDGE_START_HOUR=8
DAILY_NUDGE_END_HOUR=20
PARSER_AI_CONFIDENCE_THRESHOLD=0.80
WEEKLY_CLOSURE_HOUR=9

# Provedor de IA para relatorios
# Runtime atual usa cliente OpenAI-compatible, mas o padrao do projeto agora e Mistral.
# Se quiser, tambem pode usar OPENAI_API_KEY em vez de MISTRAL_API_KEY.
MISTRAL_API_KEY=
OPENAI_MODEL=mistral-small-latest
OPENAI_BASE_URL=https://api.mistral.ai/v1
MISTRAL_TRANSCRIPTION_MODEL=voxtral-mini-latest
MISTRAL_TRANSCRIPTION_LANGUAGE=pt

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=
REPORT_EMAIL_SUBJECT=Seu relatorio financeiro ChamaLeon
