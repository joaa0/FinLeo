# FinBot Telegram — Configuração de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais

# Token do Telegram Bot (obtenha com @BotFather)
TELEGRAM_BOT_TOKEN=8729145296:AAFNvsbpzDk0ZGc4PGEWYs74e6CV--7KmC4

# Webhook URL do Zapier
# Obtenha em: Zapier → New Zap → Webhooks by Zapier → Catch raw hook
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/zxczxcxzcxz

# Google Sheets Configuration
# ID da planilha (obtenha da URL)
GOOGLE_SHEET_ID=seuidgooglesheets123539028590

# Caminho para o arquivo de credenciais JSON do Google (local)
# OU use GOOGLE_CREDENTIALS_JSON em vez disso
GOOGLE_CREDENTIALS_PATH="credentials-1239021329031.json"

# (Alternativa para Railway) Cole o conteúdo JSON completo aqui
# Se usar isso, deixe GOOGLE_CREDENTIALS_PATH vazio
GOOGLE_CREDENTIALS_JSON=

# Nome da sheet onde estão as transações
# (Padrão: transactions)
SHEET_NAME=transactions

# (Opcional) Nível de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

