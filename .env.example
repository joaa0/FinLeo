# FinBot Telegram — Configuração de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais

# Token do Telegram Bot (obtenha com @BotFather)
TELEGRAM_BOT_TOKEN=seu_token_aqui_123456789:ABCDEFghijklmnopqrstuvwxyz

# Webhook URL do Zapier
# Obtenha em: Zapier → New Zap → Webhooks by Zapier → Catch raw hook
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx/yyyy/

# (Opcional) Google Sheets ID - para integrações futuras
GOOGLE_SHEETS_ID=seu_sheet_id_aqui

# (Opcional) Nível de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
